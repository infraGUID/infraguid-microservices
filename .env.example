# ============================================================
# InfraGuidAI — Environment Configuration
# ============================================================
#
# SECRETS MANAGEMENT:
# In production, set AWS_SECRET_NAME to your Secrets Manager secret.
# The app will fetch sensitive values (POSTGRES_URI, COGNITO_*, etc.)
# from Secrets Manager at startup. Terraform provisions the secret.
#
# In local development, leave AWS_SECRET_NAME empty and set values
# directly in this file. The .env file takes precedence.
# ============================================================

APP_ENV=development
LOG_LEVEL=INFO

FRONTEND_ORIGIN=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Secrets Manager (production only) ---
# Set this to the Secrets Manager secret name/ARN provisioned by Terraform.
# When set, the app loads POSTGRES_URI, COGNITO_*, and other sensitive
# values from the secret JSON, so you DON'T need to set them below.
# AWS_SECRET_NAME=infraguidai/prod/app-secrets

# --- PostgreSQL (RDS) ---
# In production: loaded from Secrets Manager
# In development: set directly here
POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/infraguid

# --- Redis (Ephemeral Session Store) ---
# docker-compose overrides this to redis://redis:6379/0 automatically.
# On EKS / production: point at your ElastiCache Redis endpoint.
#   REDIS_URL=redis://your-elasticache-endpoint:6379/0
# For TLS-secured ElastiCache (recommended in prod):
#   REDIS_URL=rediss://your-elasticache-endpoint:6380/0
REDIS_URL=redis://localhost:6379/0

# Session TTL in seconds. Refreshed on every message; idle sessions expire.
# 7200 = 2 hours. Increase for longer-lived sessions if needed.
SESSION_TTL_SECONDS=7200

# --- S3 Document Storage ---
S3_DOCUMENT_BUCKET=infraguidai-documents

# --- Knowledge Base ---
KNOWLEDGE_BASE_PATH=./knowledge-base
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RAG_TOP_K=5

# --- AWS ---
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=      # Only for local dev; EC2/EKS uses IAM role
# AWS_SECRET_ACCESS_KEY=   # Only for local dev; EC2/EKS uses IAM role
# AWS_SESSION_TOKEN=       # Only for temporary credentials

# --- Bedrock ---
BEDROCK_CHAT_MODEL_ID=us.meta.llama3-1-8b-instruct-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- Cognito ---
# In production: loaded from Secrets Manager
# In development: set directly here
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=us-east-1

# --- Inter-service URLs (microservices, sync REST) ---
# In docker-compose these are overridden to the service names. For running a
# single service locally outside compose, point them at the right localhost port.
# On EKS: set to the Kubernetes service DNS names (e.g. http://agent-service:8001).
AGENT_SERVICE_URL=http://localhost:8001
RAG_SERVICE_URL=http://localhost:8002
INGESTION_SERVICE_URL=http://localhost:8003
